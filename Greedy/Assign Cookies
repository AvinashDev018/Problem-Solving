class Solution {
    public int findContentChildren(int[] g, int[] s) {
        if(s.length==0) return 0;
        int max=0;
        Arrays.sort(s);
        Arrays.sort(g);
        int child=g.length-1;
        int cookie=s.length-1;
        while(child>=0 && cookie>=0){
            if(g[child]<=s[cookie]){
                max++;
                child--;
                cookie--;
            }else child--;
        }
        return max;
    }
}

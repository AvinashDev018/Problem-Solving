class Solution {
    public int findPlatform(int[] Arrival, int[] Departure) {
        //your code goes here
        Arrays.sort(Arrival);
        Arrays.sort(Departure);
        int pf=1;
        int res=1;
        int i=1,j=0;
        while(i<n && j<n){
            if(Arrival[i]<=Departure[j]){
                pf++;
                i++;
            }else{
                pf--;
                j++;
            }
            res=Math.max(res,pf);
        }
        return res;
    }
}

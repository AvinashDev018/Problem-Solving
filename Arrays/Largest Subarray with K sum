class Solution {
    public int longestSubarray(int[] nums, int k) {
       int max=0;
       int sum=0;
       Map<Integer,Integer> mp=new HashMap<>();
       mp.put(0,-1);
       for(int i=0;i<nums.length;i++){
        sum+=nums[i];
        if(mp.containsKey(sum-k)){
            max=Math.max(max,i-mp.get(sum-k));
        }else{
            mp.put(sum,i);
        }
       }
       return max;
    }
}

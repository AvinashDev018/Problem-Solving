class Solution {
    public int[] findMissingRepeatingNumbers(int[] nums) {
        int n=nums.length;
        int[] freq=new int[n+1];
        for(int i=0;i<n;i++){
            freq[nums[i]]++;
        }
        int miss=-1;
        int rep=-1;
        for(int i=1;i<n+1;i++){
            if(freq[i]==2) rep=i;
            else if(freq[i]==0) miss=i;
            if(miss!=-1 && rep!=-1) break;
        }
        return new int[]{rep,miss};
    }
}
